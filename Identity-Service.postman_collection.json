
{
	"info": {
		"name": "Voucher Loyalty Microservices",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "identityUrl", "value": "http://localhost:8081" },
		{ "key": "voucherUrl", "value": "http://localhost:8082" },
		{ "key": "accessToken", "value": "" },
		{ "key": "refreshToken", "value": "" },
		{ "key": "userId", "value": "" },
		{ "key": "voucherId", "value": "1" },
		{ "key": "missionId", "value": "1" }
	],
	"auth": {
		"type": "bearer",
		"bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
	},
	"item": [
		{
			"name": "Identity Service",
			"item": [
				{
					"name": "Auth",
					"item": [
						{
							"name": "Login",
							"event": [{
								"listen": "test",
								"script": {
									"exec": [
										"var jsonData = pm.response.json();",
										"if (jsonData.data && jsonData.data.accessToken) {",
										"    pm.collectionVariables.set('accessToken', jsonData.data.accessToken);",
										"}",
										"if (jsonData.data && jsonData.data.refreshToken) {",
										"    pm.collectionVariables.set('refreshToken', jsonData.data.refreshToken);",
										"}"
									],
									"type": "text/javascript"
								}
							}],
							"request": {
								"auth": { "type": "noauth" },
								"method": "POST",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"username\": \"admin\",\n    \"password\": \"admin123\"\n}"
								},
								"url": {
									"raw": "{{identityUrl}}/api/v1/auth/login",
									"host": ["{{identityUrl}}"],
									"path": ["api", "v1", "auth", "login"]
								}
							}
						},
						{
							"name": "Register Customer",
							"request": {
								"auth": { "type": "noauth" },
								"method": "POST",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"username\": \"customer01\",\n    \"password\": \"password123\",\n    \"email\": \"customer@example.com\",\n    \"firstName\": \"Nguyen\",\n    \"lastName\": \"Van A\"\n}"
								},
								"url": {
									"raw": "{{identityUrl}}/api/v1/auth/register",
									"host": ["{{identityUrl}}"],
									"path": ["api", "v1", "auth", "register"]
								}
							}
						},
						{
							"name": "Refresh Token",
							"event": [{
								"listen": "test",
								"script": {
									"exec": [
										"var jsonData = pm.response.json();",
										"if (jsonData.data && jsonData.data.accessToken) {",
										"    pm.collectionVariables.set('accessToken', jsonData.data.accessToken);",
										"}"
									],
									"type": "text/javascript"
								}
							}],
							"request": {
								"auth": { "type": "noauth" },
								"method": "POST",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"refreshToken\": \"{{refreshToken}}\"\n}"
								},
								"url": {
									"raw": "{{identityUrl}}/api/v1/auth/refresh",
									"host": ["{{identityUrl}}"],
									"path": ["api", "v1", "auth", "refresh"]
								}
							}
						},
						{
							"name": "Get Allowed Pages",
							"request": {
								"auth": { "type": "noauth" },
								"method": "POST",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"roles\": [\"ADMIN\", \"MERCHANT\"]\n}"
								},
								"url": {
									"raw": "{{identityUrl}}/api/v1/auth/allowed-pages",
									"host": ["{{identityUrl}}"],
									"path": ["api", "v1", "auth", "allowed-pages"]
								}
							}
						}
					]
				},
				{
					"name": "Profile",
					"item": [
						{
							"name": "Get Profile",
							"request": {
								"method": "GET",
								"url": {
									"raw": "{{identityUrl}}/api/v1/profile",
									"host": ["{{identityUrl}}"],
									"path": ["api", "v1", "profile"]
								}
							}
						},
						{
							"name": "Update Profile",
							"request": {
								"method": "PUT",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"firstName\": \"John\",\n    \"lastName\": \"Doe\",\n    \"email\": \"john.doe@example.com\",\n    \"phone\": \"0123456789\",\n    \"storeName\": \"My Store\"\n}"
								},
								"url": {
									"raw": "{{identityUrl}}/api/v1/profile",
									"host": ["{{identityUrl}}"],
									"path": ["api", "v1", "profile"]
								}
							}
						},
						{
							"name": "Change Password",
							"request": {
								"method": "PUT",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"currentPassword\": \"oldPassword123\",\n    \"newPassword\": \"newPassword456\"\n}"
								},
								"url": {
									"raw": "{{identityUrl}}/api/v1/profile/password",
									"host": ["{{identityUrl}}"],
									"path": ["api", "v1", "profile", "password"]
								}
							}
						}
					]
				},
				{
					"name": "Roles",
					"item": [
						{
							"name": "Get All Roles",
							"request": {
								"method": "GET",
								"url": {
									"raw": "{{identityUrl}}/api/v1/roles",
									"host": ["{{identityUrl}}"],
									"path": ["api", "v1", "roles"]
								}
							}
						},
						{
							"name": "Create Role",
							"request": {
								"method": "POST",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"name\": \"NEW_ROLE\",\n    \"description\": \"A new custom role\",\n    \"attributes\": {\n        \"allowedPages\": [\"dashboard\", \"reports\"]\n    }\n}"
								},
								"url": {
									"raw": "{{identityUrl}}/api/v1/roles",
									"host": ["{{identityUrl}}"],
									"path": ["api", "v1", "roles"]
								}
							}
						},
						{
							"name": "Get Role By Name",
							"request": {
								"method": "GET",
								"url": {
									"raw": "{{identityUrl}}/api/v1/roles/ADMIN",
									"host": ["{{identityUrl}}"],
									"path": ["api", "v1", "roles", "ADMIN"]
								}
							}
						},
						{
							"name": "Update Role",
							"request": {
								"method": "PUT",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"description\": \"Updated role description\"\n}"
								},
								"url": {
									"raw": "{{identityUrl}}/api/v1/roles/NEW_ROLE",
									"host": ["{{identityUrl}}"],
									"path": ["api", "v1", "roles", "NEW_ROLE"]
								}
							}
						},
						{
							"name": "Delete Role",
							"request": {
								"method": "DELETE",
								"url": {
									"raw": "{{identityUrl}}/api/v1/roles/NEW_ROLE",
									"host": ["{{identityUrl}}"],
									"path": ["api", "v1", "roles", "NEW_ROLE"]
								}
							}
						},
						{
							"name": "Update Role Attributes",
							"request": {
								"method": "PUT",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"allowedPages\": [\"dashboard\", \"reports\", \"settings\"]\n}"
								},
								"url": {
									"raw": "{{identityUrl}}/api/v1/roles/ADMIN/attributes",
									"host": ["{{identityUrl}}"],
									"path": ["api", "v1", "roles", "ADMIN", "attributes"]
								}
							}
						}
					]
				},
				{
					"name": "System Users",
					"item": [
						{
							"name": "Get All Users",
							"request": {
								"method": "GET",
								"url": {
									"raw": "{{identityUrl}}/api/v1/system-users",
									"host": ["{{identityUrl}}"],
									"path": ["api", "v1", "system-users"]
								}
							}
						},
						{
							"name": "Create User (Admin)",
							"request": {
								"method": "POST",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"username\": \"newadmin\",\n    \"password\": \"password123\",\n    \"email\": \"newadmin@example.com\",\n    \"firstName\": \"New\",\n    \"lastName\": \"Admin\",\n    \"enabled\": true,\n    \"role\": \"ADMIN\"\n}"
								},
								"url": {
									"raw": "{{identityUrl}}/api/v1/system-users",
									"host": ["{{identityUrl}}"],
									"path": ["api", "v1", "system-users"]
								}
							}
						},
						{
							"name": "Create User (Merchant)",
							"request": {
								"method": "POST",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"username\": \"merchant01\",\n    \"password\": \"password123\",\n    \"email\": \"merchant@example.com\",\n    \"firstName\": \"Store\",\n    \"lastName\": \"Owner\",\n    \"enabled\": true,\n    \"role\": \"MERCHANT\",\n    \"storeName\": \"Coffee Shop\",\n    \"phone\": \"0987654321\",\n    \"category\": \"FOOD\"\n}"
								},
								"url": {
									"raw": "{{identityUrl}}/api/v1/system-users",
									"host": ["{{identityUrl}}"],
									"path": ["api", "v1", "system-users"]
								}
							}
						},
						{
							"name": "Update User",
							"request": {
								"method": "PUT",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"email\": \"updated@example.com\",\n    \"firstName\": \"Updated\",\n    \"lastName\": \"Name\",\n    \"enabled\": true,\n    \"storeName\": \"Updated Store\",\n    \"phone\": \"0111222333\",\n    \"category\": \"BEVERAGE\",\n    \"status\": \"ACTIVE\"\n}"
								},
								"url": {
									"raw": "{{identityUrl}}/api/v1/system-users/{{userId}}",
									"host": ["{{identityUrl}}"],
									"path": ["api", "v1", "system-users", "{{userId}}"]
								}
							}
						},
						{
							"name": "Delete User",
							"request": {
								"method": "DELETE",
								"url": {
									"raw": "{{identityUrl}}/api/v1/system-users/{{userId}}",
									"host": ["{{identityUrl}}"],
									"path": ["api", "v1", "system-users", "{{userId}}"]
								}
							}
						},
						{
							"name": "Reset Password",
							"request": {
								"method": "POST",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"password\": \"newPassword123\"\n}"
								},
								"url": {
									"raw": "{{identityUrl}}/api/v1/system-users/{{userId}}/reset-password",
									"host": ["{{identityUrl}}"],
									"path": ["api", "v1", "system-users", "{{userId}}", "reset-password"]
								}
							}
						}
					]
				}
			]
		},
		{
			"name": "Voucher Service",
			"item": [
				{
					"name": "Vouchers",
					"item": [
						{
							"name": "Create Voucher",
							"request": {
								"method": "POST",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"voucherName\": \"Summer Sale 50K\",\n    \"description\": \"Discount 50K for orders over 200K\",\n    \"voucherPurpose\": \"HUNT\",\n    \"customerTier\": \"ALL\",\n    \"discountType\": \"FIXED\",\n    \"discountValue\": 50000,\n    \"maxDiscount\": 50000,\n    \"minOrderValue\": 200000,\n    \"totalStock\": 100,\n    \"maxCollect\": 1,\n    \"startDate\": \"2026-05-01T00:00:00\",\n    \"endDate\": \"2026-06-30T23:59:59\"\n}"
								},
								"url": {
									"raw": "{{voucherUrl}}/api/v1/vouchers",
									"host": ["{{voucherUrl}}"],
									"path": ["api", "v1", "vouchers"]
								}
							}
						},
						{
							"name": "Create Voucher By Excel",
							"request": {
								"method": "POST",
								"body": {
									"mode": "formdata",
									"formdata": [
										{ "key": "file", "type": "file", "src": "" },
										{ "key": "voucherPurpose", "value": "HUNT", "type": "text" }
									]
								},
								"url": {
									"raw": "{{voucherUrl}}/api/v1/vouchers/excel",
									"host": ["{{voucherUrl}}"],
									"path": ["api", "v1", "vouchers", "excel"]
								}
							}
						},
						{
							"name": "Get Voucher Requests",
							"request": {
								"method": "GET",
								"url": {
									"raw": "{{voucherUrl}}/api/v1/vouchers?page=0&size=20",
									"host": ["{{voucherUrl}}"],
									"path": ["api", "v1", "vouchers"],
									"query": [
										{ "key": "status", "value": "INIT", "disabled": true },
										{ "key": "requestMode", "value": "SINGLE", "disabled": true },
										{ "key": "creatorType", "value": "SYSTEM", "disabled": true },
										{ "key": "voucherPurpose", "value": "HUNT", "disabled": true },
										{ "key": "storeName", "value": "", "disabled": true },
										{ "key": "fromDate", "value": "2026-01-01T00:00:00", "disabled": true },
										{ "key": "toDate", "value": "2026-12-31T23:59:59", "disabled": true },
										{ "key": "page", "value": "0" },
										{ "key": "size", "value": "20" }
									]
								}
							}
						},
						{
							"name": "Get Voucher Details",
							"request": {
								"method": "GET",
								"url": {
									"raw": "{{voucherUrl}}/api/v1/vouchers/details?page=0&size=20",
									"host": ["{{voucherUrl}}"],
									"path": ["api", "v1", "vouchers", "details"],
									"query": [
										{ "key": "creatorType", "value": "SYSTEM", "disabled": true },
										{ "key": "customerTier", "value": "ALL", "disabled": true },
										{ "key": "discountType", "value": "FIXED", "disabled": true },
										{ "key": "voucherPurpose", "value": "HUNT", "disabled": true },
										{ "key": "voucherStatus", "value": "ACTIVE", "disabled": true },
										{ "key": "storeName", "value": "", "disabled": true },
										{ "key": "fromDate", "value": "2026-01-01T00:00:00", "disabled": true },
										{ "key": "toDate", "value": "2026-12-31T23:59:59", "disabled": true },
										{ "key": "page", "value": "0" },
										{ "key": "size", "value": "20" }
									]
								}
							}
						},
						{
							"name": "Get Voucher By Id",
							"request": {
								"method": "GET",
								"url": {
									"raw": "{{voucherUrl}}/api/v1/vouchers/{{voucherId}}?page=0&size=20",
									"host": ["{{voucherUrl}}"],
									"path": ["api", "v1", "vouchers", "{{voucherId}}"],
									"query": [
										{ "key": "voucherName", "value": "", "disabled": true },
										{ "key": "status", "value": "INIT", "disabled": true },
										{ "key": "page", "value": "0" },
										{ "key": "size", "value": "20" }
									]
								}
							}
						},
						{
							"name": "Submit Voucher",
							"request": {
								"method": "PUT",
								"url": {
									"raw": "{{voucherUrl}}/api/v1/vouchers/{{voucherId}}/submit",
									"host": ["{{voucherUrl}}"],
									"path": ["api", "v1", "vouchers", "{{voucherId}}", "submit"]
								}
							}
						},
						{
							"name": "Confirm Voucher (Approve)",
							"request": {
								"method": "PUT",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"action\": \"APPROVED\"\n}"
								},
								"url": {
									"raw": "{{voucherUrl}}/api/v1/vouchers/{{voucherId}}/confirm",
									"host": ["{{voucherUrl}}"],
									"path": ["api", "v1", "vouchers", "{{voucherId}}", "confirm"]
								}
							}
						},
						{
							"name": "Confirm Voucher (Reject)",
							"request": {
								"method": "PUT",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"action\": \"REJECTED\",\n    \"reason\": \"Discount value too high\"\n}"
								},
								"url": {
									"raw": "{{voucherUrl}}/api/v1/vouchers/{{voucherId}}/confirm",
									"host": ["{{voucherUrl}}"],
									"path": ["api", "v1", "vouchers", "{{voucherId}}", "confirm"]
								}
							}
						},
						{
							"name": "Cancel Voucher",
							"request": {
								"method": "PUT",
								"url": {
									"raw": "{{voucherUrl}}/api/v1/vouchers/{{voucherId}}/cancel",
									"host": ["{{voucherUrl}}"],
									"path": ["api", "v1", "vouchers", "{{voucherId}}", "cancel"]
								}
							}
						}
					]
				},
				{
					"name": "Missions",
					"item": [
						{
							"name": "Create Mission",
							"request": {
								"method": "POST",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"missionName\": \"Spend 500K\",\n    \"missionDescription\": \"Complete orders totaling 500K to earn reward\",\n    \"targetValue\": 500000,\n    \"rewardType\": \"POINT\",\n    \"rewardValue\": \"100\",\n    \"partnerId\": null,\n    \"missionStartDate\": \"2026-05-01T00:00:00\",\n    \"missionEndDate\": \"2026-06-30T23:59:59\",\n    \"voucherName\": \"Mission Voucher\",\n    \"description\": \"Voucher from mission\",\n    \"discountType\": \"FIXED\",\n    \"discountValue\": 30000,\n    \"maxDiscount\": 30000,\n    \"minOrderValue\": 100000,\n    \"totalStock\": 50,\n    \"maxCollect\": 1,\n    \"startDate\": \"2026-05-01T00:00:00\",\n    \"endDate\": \"2026-06-30T23:59:59\"\n}"
								},
								"url": {
									"raw": "{{voucherUrl}}/api/v1/missions/missions",
									"host": ["{{voucherUrl}}"],
									"path": ["api", "v1", "missions", "missions"]
								}
							}
						},
						{
							"name": "Get Mission Detail",
							"request": {
								"method": "GET",
								"url": {
									"raw": "{{voucherUrl}}/api/v1/missions/missions/{{missionId}}",
									"host": ["{{voucherUrl}}"],
									"path": ["api", "v1", "missions", "missions", "{{missionId}}"]
								}
							}
						},
						{
							"name": "Search Missions",
							"request": {
								"method": "GET",
								"url": {
									"raw": "{{voucherUrl}}/api/v1/missions/search?page=0&size=20",
									"host": ["{{voucherUrl}}"],
									"path": ["api", "v1", "missions", "search"],
									"query": [
										{ "key": "nameStore", "value": "", "disabled": true },
										{ "key": "rewardType", "value": "POINT", "disabled": true },
										{ "key": "taskStatus", "value": "INIT", "disabled": true },
										{ "key": "page", "value": "0" },
										{ "key": "size", "value": "20" }
									]
								}
							}
						},
						{
							"name": "Submit Mission",
							"request": {
								"method": "PUT",
								"url": {
									"raw": "{{voucherUrl}}/api/v1/missions/missions/{{missionId}}/submit",
									"host": ["{{voucherUrl}}"],
									"path": ["api", "v1", "missions", "missions", "{{missionId}}", "submit"]
								}
							}
						},
						{
							"name": "Confirm Mission (Approve)",
							"request": {
								"method": "PUT",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"action\": \"APPROVED\"\n}"
								},
								"url": {
									"raw": "{{voucherUrl}}/api/v1/missions/missions/{{missionId}}/confirm",
									"host": ["{{voucherUrl}}"],
									"path": ["api", "v1", "missions", "missions", "{{missionId}}", "confirm"]
								}
							}
						},
						{
							"name": "Confirm Mission (Reject)",
							"request": {
								"method": "PUT",
								"header": [{ "key": "Content-Type", "value": "application/json" }],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"action\": \"REJECTED\",\n    \"reason\": \"Target value too low\"\n}"
								},
								"url": {
									"raw": "{{voucherUrl}}/api/v1/missions/missions/{{missionId}}/confirm",
									"host": ["{{voucherUrl}}"],
									"path": ["api", "v1", "missions", "missions", "{{missionId}}", "confirm"]
