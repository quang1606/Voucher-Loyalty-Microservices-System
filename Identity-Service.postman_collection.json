{
	"info": {
		"name": "Identity Service",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8081"
		},
		{
			"key": "accessToken",
			"value": ""
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{accessToken}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.accessToken) {",
									"    pm.collectionVariables.set('accessToken', jsonData.data.accessToken);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"admin\",\n    \"password\": \"admin123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "login"]
						}
					}
				},
				{
					"name": "Register Customer",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"customer01\",\n    \"password\": \"password123\",\n    \"email\": \"customer@example.com\",\n    \"firstName\": \"Nguyen\",\n    \"lastName\": \"Van A\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "register"]
						}
					}
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.accessToken) {",
									"    pm.collectionVariables.set('accessToken', jsonData.data.accessToken);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refreshToken\": \"your-refresh-token-here\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/refresh",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "refresh"]
						}
					}
				},
				{
					"name": "Get Allowed Pages",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"roles\": [\"ADMIN\", \"MERCHANT\"]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/allowed-pages",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "allowed-pages"]
						}
					}
				}
			]
		},
		{
			"name": "Profile",
			"item": [
				{
					"name": "Get Profile",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/profile",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "profile"]
						}
					}
				},
				{
					"name": "Update Profile",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"firstName\": \"John\",\n    \"lastName\": \"Doe\",\n    \"email\": \"john.doe@example.com\",\n    \"phone\": \"0123456789\",\n    \"storeName\": \"My Store\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/profile",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "profile"]
						}
					}
				},
				{
					"name": "Change Password",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"currentPassword\": \"oldPassword123\",\n    \"newPassword\": \"newPassword456\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/profile/password",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "profile", "password"]
						}
					}
				}
			]
		},
		{
			"name": "Roles",
			"item": [
				{
					"name": "Get All Roles",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/roles",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "roles"]
						}
					}
				},
				{
					"name": "Create Role",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"NEW_ROLE\",\n    \"description\": \"A new custom role\",\n    \"attributes\": {\n        \"allowedPages\": [\"dashboard\", \"reports\"]\n    }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/roles",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "roles"]
						}
					}
				},
				{
					"name": "Get Role By Name",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/roles/ADMIN",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "roles", "ADMIN"]
						}
					}
				},
				{
					"name": "Update Role",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"description\": \"Updated role description\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/roles/NEW_ROLE",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "roles", "NEW_ROLE"]
						}
					}
				},
				{
					"name": "Delete Role",
					"request": {
						"method": "DELETE",
						"url": {
							"raw": "{{baseUrl}}/api/v1/roles/NEW_ROLE",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "roles", "NEW_ROLE"]
						}
					}
				},
				{
					"name": "Update Role Attributes",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"allowedPages\": [\"dashboard\", \"reports\", \"settings\"]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/roles/ADMIN/attributes",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "roles", "ADMIN", "attributes"]
						}
					}
				}
			]
		},
		{
			"name": "System Users",
			"item": [
				{
					"name": "Get All Users",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/v1/system-users",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "system-users"]
						}
					}
				},
				{
					"name": "Create User (Admin)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"newadmin\",\n    \"password\": \"password123\",\n    \"email\": \"newadmin@example.com\",\n    \"firstName\": \"New\",\n    \"lastName\": \"Admin\",\n    \"enabled\": true,\n    \"role\": \"ADMIN\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/system-users",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "system-users"]
						}
					}
				},
				{
					"name": "Create User (Merchant)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"merchant01\",\n    \"password\": \"password123\",\n    \"email\": \"merchant@example.com\",\n    \"firstName\": \"Store\",\n    \"lastName\": \"Owner\",\n    \"enabled\": true,\n    \"role\": \"MERCHANT\",\n    \"storeName\": \"Coffee Shop\",\n    \"phone\": \"0987654321\",\n    \"category\": \"FOOD\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/system-users",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "system-users"]
						}
					}
				},
				{
					"name": "Update User",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"updated@example.com\",\n    \"firstName\": \"Updated\",\n    \"lastName\": \"Name\",\n    \"enabled\": true,\n    \"storeName\": \"Updated Store\",\n    \"phone\": \"0111222333\",\n    \"category\": \"BEVERAGE\",\n    \"status\": \"ACTIVE\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/system-users/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "system-users", "{{userId}}"]
						}
					}
				},
				{
					"name": "Delete User",
					"request": {
						"method": "DELETE",
						"url": {
							"raw": "{{baseUrl}}/api/v1/system-users/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "system-users", "{{userId}}"]
						}
					}
				},
				{
					"name": "Reset Password",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"password\": \"newPassword123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/system-users/{{userId}}/reset-password",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "system-users", "{{userId}}", "reset-password"]
						}
					}
				}
			]
		}
	]
}
