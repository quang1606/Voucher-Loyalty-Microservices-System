{
  "baseUrl": "/api/v1/vouchers",
  "authentication": "Bearer JWT Token (Keycloak)",
  "responseFormat": {
    "status": "int — 0 = success",
    "code": "string — error code",
    "message": "string — mô tả",
    "data": "object | null"
  },
  "errorResponses": {
    "businessError": {
      "httpStatus": 400,
      "example": {
        "status": 400,
        "code": "INVALID_FIXED_VOUCHER",
        "message": "Discount value must not exceed min order value",
        "data": null
      }
    },
    "validationError": {
      "httpStatus": 400,
      "example": {
        "status": 1001,
        "code": "VALIDATION_ERROR",
        "message": "voucherName: Voucher name is required, discountType: Discount type is required",
        "data": null
      }
    },
    "unauthorized": {
      "httpStatus": 401,
      "example": {
        "status": 1002,
        "code": "UNAUTHORIZED",
        "message": "Unauthorized",
        "data": null
      }
    },
    "notFound": {
      "httpStatus": 404,
      "example": {
        "status": 1003,
        "code": "NOT_FOUND",
        "message": "Resource not found",
        "data": null
      }
    },
    "internalError": {
      "httpStatus": 500,
      "example": {
        "status": 1006,
        "code": "INTERNAL_ERROR",
        "message": "Internal server error",
        "data": null
      }
    }
  },
  "enums": {
    "DiscountType": ["FIXED", "PERCENT"],
    "RequestStatus": ["DRAFT", "CANCELLED", "PENDING_APPROVE", "INIT", "APPROVED", "REJECTED", "PROCESSING", "FAILED", "FINISH", "SUCCESS"],
    "CustomerTier": ["ALL", "SILVER", "GOLD", "PLATINUM", "DIAMOND"],
    "VoucherPurpose": ["REWARD", "HUNT"],
    "RequestMode": ["SINGLE", "EXCEL"],
    "CreatorType": ["SYSTEM", "MERCHANT"]
  },
  "apis": [
    {
      "name": "Tạo voucher (single)",
      "method": "POST",
      "url": "/api/v1/vouchers",
      "roles": ["MAKER", "PARTNER"],
      "contentType": "application/json",
      "request": {
        "body": {
          "voucherName": { "type": "string", "required": true, "example": "Giảm 50K" },
          "description": { "type": "string", "required": true, "example": "Voucher giảm 50K cho đơn từ 200K" },
          "customerTier": { "type": "enum", "required": false, "values": ["ALL", "SILVER", "GOLD", "PLATINUM", "DIAMOND"], "example": "ALL" },
          "discountType": { "type": "enum", "required": true, "values": ["FIXED", "PERCENT"], "example": "FIXED" },
          "discountValue": { "type": "number", "required": true, "example": 50000 },
          "maxDiscount": { "type": "number", "required": "bắt buộc nếu PERCENT", "example": 100000 },
          "minOrderValue": { "type": "number", "required": "bắt buộc nếu FIXED", "example": 200000 },
          "totalStock": { "type": "integer", "required": true, "example": 1000 },
          "maxCollect": { "type": "integer", "required": false, "example": 1 },
          "startDate": { "type": "datetime", "required": true, "format": "yyyy-MM-ddTHH:mm:ss", "example": "2025-07-01T00:00:00" },
          "endDate": { "type": "datetime", "required": true, "format": "yyyy-MM-ddTHH:mm:ss", "example": "2025-07-31T23:59:59" }
        },
        "example": {
          "voucherName": "Giảm 50K",
          "description": "Voucher giảm 50K cho đơn từ 200K",
          "customerTier": "ALL",
          "discountType": "FIXED",
          "discountValue": 50000,
          "maxDiscount": null,
          "minOrderValue": 200000,
          "totalStock": 1000,
          "maxCollect": 1,
          "startDate": "2025-07-01T00:00:00",
          "endDate": "2025-07-31T23:59:59"
        }
      },
      "response": {
        "httpStatus": 200,
        "example": {
          "status": 0,
          "code": "success",
          "message": "Success",
          "data": null
        }
      },
      "errors": [
        { "code": "INVALID_FIXED_VOUCHER", "message": "Min order value is required for FIXED discount" },
        { "code": "INVALID_FIXED_VOUCHER", "message": "Discount value must not exceed min order value" },
        { "code": "INVALID_PERCENT_VOUCHER", "message": "Max discount is required for PERCENT discount" },
        { "code": "INVALID_PERCENT_VOUCHER", "message": "Discount percentage must not exceed 100" }
      ]
    },
    {
      "name": "Tạo voucher bằng Excel",
      "method": "POST",
      "url": "/api/v1/vouchers/excel",
      "roles": ["MAKER", "PARTNER"],
      "contentType": "multipart/form-data",
      "request": {
        "fields": {
          "file": { "type": "File", "required": true, "description": "File Excel (.xlsx)" },
          "discountType": { "type": "enum", "required": true, "values": ["FIXED", "PERCENT"] },
          "requestId": { "type": "string", "required": true, "description": "ID của request đã tạo" }
        }
      },
      "response": {
        "httpStatus": 200,
        "example": {
          "status": 0,
          "code": "success",
          "message": "Success",
          "data": null
        }
      },
      "errors": [
        { "code": "VALIDATION_ERROR", "message": "file: file is required" },
        { "code": "VALIDATION_ERROR", "message": "requestType: requestType is required" },
        { "code": "VALIDATION_ERROR", "message": "requestId: requestId is required" }
      ]
    },
    {
      "name": "Lấy danh sách voucher request",
      "method": "GET",
      "url": "/api/v1/vouchers",
      "roles": ["MAKER", "CHECKER", "PARTNER"],
      "request": {
        "queryParams": {
          "status": { "type": "enum", "required": false, "values": ["DRAFT", "CANCELLED", "PENDING_APPROVE", "INIT", "APPROVED", "REJECTED", "PROCESSING", "FAILED", "FINISH", "SUCCESS"] },
          "fromDate": { "type": "datetime", "required": false, "format": "yyyy-MM-ddTHH:mm:ss", "example": "2025-01-01T00:00:00" },
          "toDate": { "type": "datetime", "required": false, "format": "yyyy-MM-ddTHH:mm:ss", "example": "2025-07-31T23:59:59" },
          "partnerId": { "type": "string", "required": false },
          "requestType": { "type": "enum", "required": false, "values": ["FIXED", "PERCENT"] },
          "page": { "type": "integer", "required": false, "default": 0 },
          "size": { "type": "integer", "required": false, "default": 20 },
          "sort": { "type": "string", "required": false, "example": "createdTime,desc" }
        }
      },
      "response": {
        "httpStatus": 200,
        "example": {
          "status": 0,
          "code": "success",
          "message": "Success",
          "data": {
            "content": [
              {
                "id": 1,
                "requestId": "REQ-20250701-001",
                "requestMode": "SINGLE",
                "creatorType": "SYSTEM",
                "voucherPurpose": "HUNT",
                "fileName": null,
                "status": "DRAFT",
                "reason": null,
                "createdTime": "2025-07-01T10:00:00",
                "createdBy": "maker01",
                "updatedTime": "2025-07-01T10:00:00",
                "updatedBy": null,
                "confirmedTime": null,
                "confirmedBy": null
              }
            ],
            "totalElements": 50,
            "totalPages": 3,
            "size": 20,
            "number": 0
          }
        }
      }
    },
    {
      "name": "Chi tiết voucher request",
      "method": "GET",
      "url": "/api/v1/vouchers/{requestId}",
      "roles": ["MAKER", "CHECKER", "PARTNER"],
      "request": {
        "pathParams": {
          "requestId": { "type": "long", "required": true }
        }
      },
      "response": {
        "httpStatus": 200,
        "note": "TODO — chưa implement response"
      }
    },
    {
      "name": "Submit request",
      "description": "Chuyển trạng thái DRAFT → PENDING_APPROVE",
      "method": "PUT",
      "url": "/api/v1/vouchers/{id}/submit",
      "roles": ["MAKER", "PARTNER"],
      "request": {
        "pathParams": {
          "id": { "type": "long", "required": true }
        }
      },
      "response": {
        "httpStatus": 200,
        "example": {
          "status": 0,
          "code": "success",
          "message": "Success",
          "data": null
        }
      },
      "flow": "DRAFT → PENDING_APPROVE"
    },
    {
      "name": "Confirm request (Approve/Reject)",
      "description": "Checker duyệt hoặc từ chối request",
      "method": "PUT",
      "url": "/api/v1/vouchers/{id}/confirm",
      "roles": ["CHECKER"],
      "request": {
        "pathParams": {
          "id": { "type": "long", "required": true }
        },
        "queryParams": {
          "action": { "type": "string", "required": true, "values": ["APPROVED", "REJECTED"] }
        }
      },
      "response": {
        "httpStatus": 200,
        "example": {
          "status": 0,
          "code": "success",
          "message": "Success",
          "data": null
        }
      },
      "flow": "PENDING_APPROVE → APPROVED | REJECTED"
    },
    {
      "name": "Cancel request",
      "description": "Hủy request đang ở trạng thái DRAFT",
      "method": "PUT",
      "url": "/api/v1/vouchers/{id}/cancel",
      "roles": ["MAKER", "PARTNER"],
      "request": {
        "pathParams": {
          "id": { "type": "long", "required": true }
        }
      },
      "response": {
        "httpStatus": 200,
        "example": {
          "status": 0,
          "code": "success",
          "message": "Success",
          "data": null
        }
      },
      "flow": "DRAFT → CANCELLED"
    }
  ]
}
